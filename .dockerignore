# Dependencies (reinstalled inside the image)
node_modules
**/node_modules

# Build output (regenerated by pnpm run build)
dist
dist-ssr

# Version control
.git
.gitignore
.gitattributes

# Local env files — secrets are injected as build ARGs, never copied
.env
.env.*
!.env.example

# Tooling / CI / editor — not needed for the build
.github
.vscode
.idea
e2e
playwright-report
test-results
coverage
.husky
mise.toml

# Logs and OS cruft
*.log
.DS_Store

# Docker files themselves
Dockerfile
.dockerignore
docker-compose*.yml
